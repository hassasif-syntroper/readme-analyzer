{
  "manifest_version": 3,
  "name": "Syntroper — Interactive Diagrams",
  "description": "Replaces static Syntroper diagram images on GitHub with interactive, zoomable embeds.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "https://github.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "github_csp",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Syntroper Diagrams",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
