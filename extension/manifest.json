{
  "manifest_version": 3,
  "name": "Syntroper — Interactive Diagrams",
  "description": "Replaces static Syntroper diagram images on GitHub with interactive, zoomable embeds.",
  "version": "0.1.0",
  "permissions": [],
  "host_permissions": [
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
